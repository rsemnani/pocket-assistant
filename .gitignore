# ─── Secrets / env ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.keystore
*.jks
secrets/
credentials/
*token*.json
service-account*.json

# ─── Media / sensitive runtime data (NEVER commit) ─────────────────────────────
# NOTE: anchored to runtime locations so they do NOT match source packages that
# happen to be named data/ audio/ media/ (e.g. Kotlin/Python packages).
/data/
/backend/data/
/deploy/_media/
/media/
/audio/
/transcripts/
/exports/
**/exports/
*.wav
*.mp3
*.m4a
*.ics
*.log
/logs/

# ─── Backend (Python) ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# ─── Android ───────────────────────────────────────────────────────────────────
*.apk
*.aab
/android/build/
/android/app/build/
/android/.gradle/
/android/.build-env.sh
local.properties
.cxx/
# Vosk model is large binary; fetched by scripts/fetch-vosk-model.sh, not committed.
/android/app/src/main/assets/model/

# ─── Docker / local DB ─────────────────────────────────────────────────────────
docker-compose.override.yml
pgdata/
*.sqlite
*.sqlite3
*.db

# ─── IDE / OS ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# ─── Allow sanitized test fixtures (explicit opt-in) ───────────────────────────
!backend/tests/fixtures/**/*.ics
!backend/tests/fixtures/**/*.json
