# Pocket Assistant backend — example environment.
# Copy to .env and fill real values. NEVER commit .env (only this .env.example).
# Every value below is a safe placeholder; defaults keep the app fully mocked/offline.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Local/dev default uses SQLite so the app runs with zero setup.
# On @mini use Postgres, e.g. postgresql+psycopg://user:CHANGE_ME@db:5432/pocket
DATABASE_URL=sqlite:///./pocket_dev.sqlite3

# ── Queue / cache (Phase 1 uses an in-process fallback if unset) ───────────────
REDIS_URL=redis://localhost:6379/0

# ── Media store ───────────────────────────────────────────────────────────────
MEDIA_ROOT=./data/media
MEDIA_MAX_BYTES=53687091200       # 50 GB
AUDIO_RETENTION_DAYS=30

# ── Security ──────────────────────────────────────────────────────────────────
DEVICE_TOKEN_PEPPER=CHANGE_ME     # used to hash device tokens at rest
SESSION_TTL_MINUTES=15
# Dev-only PIN for local testing. In real deployments set a real value out-of-band.
DEV_SESSION_PIN=CHANGE_ME

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=mock                 # mock | claude | openai
LLM_MODEL=                        # set when provider != mock
LLM_API_KEY=CHANGE_ME             # unused when LLM_PROVIDER=mock

# ── Integrations (all mocked by default) ──────────────────────────────────────
GMAIL_PROVIDER=mock               # mock | google
GMAIL_OAUTH_CLIENT_ID=CHANGE_ME
GMAIL_DEFAULT_WINDOW_DAYS=1

CALENDAR_PROVIDER=mock            # mock | ics_feed
CALENDAR_ICS_FEED_URL=CHANGE_ME   # private iCal feed of the aggregate calendar (secret)
WORK_HOURS_START=9
WORK_HOURS_END=17

GITHUB_PROVIDER=mock              # mock | github
GITHUB_TOKEN=CHANGE_ME
GITHUB_REPO_ALLOWLIST=OWNER/repo-a,OWNER/repo-b

CLAUDE_CODE_PROVIDER=mock         # mock | real

# ── Daily summary ─────────────────────────────────────────────────────────────
MORNING_SUMMARY_START_HOUR=5

# ── Approval policy ───────────────────────────────────────────────────────────
# In dev, every action requires approval. Keep true unless intentionally relaxing.
REQUIRE_APPROVAL_ALL=true
