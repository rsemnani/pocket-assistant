# Server stack secrets for docker-compose (copy to deploy/.env on @mini, never commit).
APP_ENV=prod
API_PORT=8000

POSTGRES_USER=pocket
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=pocket

# Host path for the media volume on @mini (e.g. /data/pocket/media). Kept out of git.
MEDIA_HOST_PATH=./_media
MEDIA_MAX_BYTES=53687091200

DEVICE_TOKEN_PEPPER=CHANGE_ME
DEV_SESSION_PIN=CHANGE_ME

# Integrations (keep mock until real credentials are provisioned with approval).
LLM_PROVIDER=mock
LLM_API_KEY=CHANGE_ME
GITHUB_REPO_ALLOWLIST=OWNER/repo-a,OWNER/repo-b
CALENDAR_ICS_FEED_URL=CHANGE_ME
